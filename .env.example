# Database
DATABASE_URL=postgresql://user:password@host:5432/database
MONGODB_URI=mongodb://user:pass@host:27017/db?authSource=admin

# Server
PORT=8080

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin
ADMIN_LEGACY_ID=your_admin_legacy_id

# AWS S3/CloudFront
S3_BUCKET=your-s3-bucket
CLOUDFRONT_HOST=your-cloudfront-host.cloudfront.net
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Razorpay
RAZORPAY_KEY_ID_TEST=rzp_live_xxxxx
RAZORPAY_KEY_SECRET_TEST=secret_xxxxx

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your_expo_token

# Business Logic
SPECIAL_CREDIT_UNLOCK_TIMEOUT_MINUTES=60
INSTANTLLY_VOUCHER_ID=your_voucher_id
AD_APPROVAL_FEE_AMOUNT=1200
PROMOTION_PAYMENT_TIMEOUT_MINUTES=30
